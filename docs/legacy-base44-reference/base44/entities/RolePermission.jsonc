{
  "name": "RolePermission",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "Role key e.g. purchaser, warehouse_keeper, process_manager, final_registrar, export_manager"
    },
    "allowed_paths": {
      "type": "string",
      "description": "JSON array of allowed route paths e.g. [\"/\", \"/purchase-registration\"]"
    }
  },
  "required": [
    "role",
    "allowed_paths"
  ]
}