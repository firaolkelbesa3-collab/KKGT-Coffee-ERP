# Copy to .env.local for local dev. Set the same values in Vercel project env.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Demo mode (optional). Set to true to turn the app into a public sandbox:
# every visitor is auto-signed-in as a shared admin "demo@kkgt.demo" account,
# Telegram alerts are suppressed, and the login screen is bypassed.
# Run `node scripts/setup-demo-user.js` once to provision the account.
# Leave unset (or set to false) for normal production auth.
VITE_DEMO_MODE=false
